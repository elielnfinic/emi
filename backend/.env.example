#--------------------------------------------------------------------
# Node
#--------------------------------------------------------------------
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

#--------------------------------------------------------------------
# App
#--------------------------------------------------------------------
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

#--------------------------------------------------------------------
# Session
#--------------------------------------------------------------------
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# Database
#--------------------------------------------------------------------
# Default driver: "sqlite" (no extra config needed) or "pg" or "mysql"
DB_CONNECTION=sqlite

# PostgreSQL / MySQL / MSSQL settings (used when DB_CONNECTION is not sqlite)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=emi

#--------------------------------------------------------------------
# Redis
#--------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

#--------------------------------------------------------------------
# SMTP (email)
#--------------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@emi.local

#--------------------------------------------------------------------
# AWS S3 (file storage)
#--------------------------------------------------------------------
S3_KEY=
S3_SECRET=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
